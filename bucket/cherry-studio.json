    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.7.22/Cherry-Studio-1.7.22-x64-setup.exe#/dl.7z",
            "hash": "sha512:a22582bc9136557aa5929cc44456892082bc66b31d8f831d6e884a86465bc5bb87281bf5f324e03cc53300da19eaa81a3eef53301642e6ba8adb7ea584e34838",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "arm64": {
            "url": "https://github.com/CherryHQ/cherry-studio/releases/download/v1.7.22/Cherry-Studio-1.7.22-arm64-setup.exe#/dl.7z",
            "hash": "59322588e8ca8c0005420a09fbeb25da77fa211ee7eeb0eb8a87ee59bc3ab300",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-arm64.7z\" \"$dir\""
